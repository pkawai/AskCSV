# Pick which LLM provider to use by default. Switchable at runtime via the
# header dropdown — that just calls POST /llm.
LLM_PROVIDER=gemini

# Google Gemini — free tier, 1500 RPD on gemini-2.5-flash.
# Get one at https://aistudio.google.com/apikey (no credit card).
GEMINI_API_KEY=AIza_replace_me

# Groq — free tier, 1000 RPD on llama-3.3-70b-versatile.
# Get one at https://console.groq.com/keys (no credit card).
GROQ_API_KEY=gsk_replace_me
